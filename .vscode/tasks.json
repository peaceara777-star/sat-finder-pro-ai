{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Python Server",
      "type": "shell",
      "command": "python app.py",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run Node.js Server",
      "type": "shell",
      "command": "cd server && npm start",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "pytest tests/ -v --cov=src",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Format Code",
      "type": "shell",
      "command": "black . && prettier --write .",
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "Docker Compose Up",
      "type": "shell",
      "command": "docker-compose up -d",
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "Docker Compose Down",
      "type": "shell",
      "command": "docker-compose down",
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "Clean Project",
      "type": "shell",
      "command": "make clean",
      "group": "none",
      "problemMatcher": []
    }
  ]
}
