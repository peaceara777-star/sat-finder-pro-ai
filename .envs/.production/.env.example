# Sat Finder Pro AI - Production Environment

# Flask
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=
PORT=5000
HOST=0.0.0.0

# Database
DATABASE_URL=
DATABASE_POOL_SIZE=20
DATABASE_POOL_TIMEOUT=30

# Redis
REDIS_URL=
REDIS_CACHE_TTL=7200

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
AI_CACHE_ENABLED=true
AI_RATE_LIMIT=100

# Security
CORS_ORIGINS=https://satfinder.example.com
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_FILE=/var/log/satfinder/app.log

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@satfinder.com

# Feature Flags
FEATURE_BETA=false
FEATURE_EXPERIMENTAL=false

# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100/hour
RATELIMIT_AI=50/day

# Cache
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
