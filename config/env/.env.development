# Sat Finder Pro AI - Development Environment
FLASK_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
PORT=5000
HOST=localhost

# Database
DATABASE_PATH=./database/satfinder_dev.db

# API
API_RATE_LIMIT=1000/hour
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080

# AI
GEMINI_MODEL=gemini-1.5-pro
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600

# Logging
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
