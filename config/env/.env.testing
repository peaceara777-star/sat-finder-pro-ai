# Sat Finder Pro AI - Testing Environment
FLASK_ENV=testing
DEBUG=true
LOG_LEVEL=DEBUG
PORT=5001
HOST=localhost

# Database
DATABASE_PATH=./database/satfinder_test.db

# API
API_RATE_LIMIT=unlimited
CORS_ORIGINS=*

# AI
GEMINI_MODEL=gemini-1.5-flash
AI_CACHE_ENABLED=false

# Logging
LOG_TO_FILE=false
LOG_TO_CONSOLE=true
