# Sat Finder Pro AI - Production Environment
FLASK_ENV=production
DEBUG=false
LOG_LEVEL=WARNING
PORT=5000
HOST=0.0.0.0

# Database
DATABASE_PATH=./database/satfinder.db

# API
API_RATE_LIMIT=100/hour
CORS_ORIGINS=https://satfinder.example.com

# AI
GEMINI_MODEL=gemini-1.5-pro
AI_CACHE_ENABLED=true
AI_CACHE_TTL=7200

# Security
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# Logging
LOG_TO_FILE=true
LOG_TO_CONSOLE=false
LOG_ROTATION=daily
LOG_RETENTION=30
